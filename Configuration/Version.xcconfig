// Single source of truth for app version and build number (CFBundleShortVersionString / CFBundleVersion).
// Included from Shikimori.xcconfig (app) and used as base for test targets.

MARKETING_VERSION = 1.2.3
CURRENT_PROJECT_VERSION = 263

// Allow per-machine signing overrides (DEVELOPMENT_TEAM, etc.) to flow into test targets too.
#include? "Local.xcconfig"
