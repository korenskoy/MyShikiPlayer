// Copy this file to Secrets.xcconfig in the same folder and fill in values.
// Secrets.xcconfig is gitignored.

SHIKIMORI_CLIENT_ID = your_client_id_here
SHIKIMORI_CLIENT_SECRET = your_client_secret_here
// Must match the OAuth Redirect URI in your Shikimori application and the URL scheme in Configuration/OAuthURLTypes.plist.
SHIKIMORI_REDIRECT_URI = myshikiplayer:/$()/oauth

// Optional: override defaults from Shikimori.xcconfig
// SHIKIMORI_BASE_URL = https:/$()/shikimori.me
// SHIKIMORI_OAUTH_BASE_URL = https:/$()/shikimori.one
// SHIKIMORI_USER_AGENT_APP_NAME = MyShikiPlayer

// Kodik /search API token (bundled into the released DMG via Info.plist key
// `KodikAPIToken`). Users can override at runtime through Settings — value
// from UserDefaults("kodik.apiToken") wins over the bundled fallback.
KODIK_API_TOKEN = your_kodik_token_here
